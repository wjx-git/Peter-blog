---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/date';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags, series } = post.data;

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={title} description={description} image={heroImage} article={true}>
  <article class="post">
    <header class="post-header">
      <div class="container">
        <div class="content-narrow">
          {series && (
            <a href={`/Peter-blog/series#${series}`} class="series-link">
              专题：{series}
            </a>
          )}
          <h1 class="post-title">{title}</h1>
          <p class="post-description">{description}</p>
          <div class="post-meta">
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            {updatedDate && (
              <span class="updated">更新于 <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
            )}
            <span class="reading-time" id="reading-time"></span>
            <span id="busuanzi_container_page_pv" class="page-views">
              阅读 <span id="busuanzi_value_page_pv">--</span>
            </span>
          </div>
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map(tag => (
                <a href={`/Peter-blog/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
              ))}
            </div>
          )}
        </div>
      </div>
      {heroImage && (
        <div class="hero-image-wrapper">
          <img src={heroImage} alt={title} class="hero-image" />
        </div>
      )}
    </header>

    <div class="container">
      <div class="content-narrow">
        <div class="post-content drop-cap">
          <slot />
        </div>

        <footer class="post-footer">
          <div class="post-tags-bottom">
            {tags.map(tag => (
              <a href={`/Peter-blog/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
          <hr />
          <div class="post-nav">
            <a href="/Peter-blog/" class="back-home">← 返回首页</a>
          </div>
        </footer>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const content = document.querySelector('.post-content');
  if (content) {
    const text = content.textContent || '';
    const minutes = Math.ceil(text.length / 600);
    const el = document.getElementById('reading-time');
    if (el) el.textContent = `约 ${minutes} 分钟阅读`;
  }
</script>

<style>
  .post-header {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .series-link {
    display: inline-block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .series-link:hover {
    text-decoration: underline;
  }

  .post-title {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.2rem;
    line-height: 1.6;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .post-meta time {
    color: var(--color-text-secondary);
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.8rem;
  }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.8rem;
    border-radius: 100px;
    font-size: 0.8rem;
    background-color: var(--color-border-light);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tag:hover {
    background-color: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  .hero-image-wrapper {
    margin: 2rem 0 0;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .hero-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
  }

  .post-content {
    padding: 2rem 0;
  }

  .post-footer {
    padding: 2rem 0 4rem;
  }

  .post-tags-bottom {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 2rem;
  }

  .back-home {
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.7rem;
    }
    .post-header {
      padding: 2rem 0 1rem;
    }
  }
</style>
