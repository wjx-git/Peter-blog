---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const seriesMap: Record<string, typeof posts> = {};
posts.forEach(post => {
  if (post.data.series) {
    if (!seriesMap[post.data.series]) seriesMap[post.data.series] = [];
    seriesMap[post.data.series].push(post);
  }
});

const seriesList = Object.entries(seriesMap)
  .filter(([_, posts]) => posts.length >= 2)
  .map(([name, posts]) => ({
    name,
    posts: posts.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0)),
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="专题">
  <div class="container">
    <div class="series-page">
      <h1 class="page-title">专题系列</h1>
      <p class="page-desc">围绕特定主题整理的系列文章</p>

      {seriesList.length === 0 && (
        <p class="empty">暂无专题系列。给文章添加相同的 "series" 字段即可自动生成专题。</p>
      )}

      <div class="series-list">
        {seriesList.map(({ name, posts }) => (
          <section class="series-section" id={name}>
            <div class="series-header">
              <h2 class="series-title">{name}</h2>
              <span class="series-badge">{posts.length} 篇</span>
            </div>
            <div class="series-posts">
              {posts.map((post, idx) => (
                <a href={`/history-blog/posts/${post.slug}/`} class="series-post">
                  <span class="series-order">{String(idx + 1).padStart(2, '0')}</span>
                  <div class="series-post-info">
                    <h3 class="series-post-title">{post.data.title}</h3>
                    <p class="series-post-desc">{post.data.description}</p>
                    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .series-page {
    padding: 2rem 0 4rem;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    text-align: center;
  }

  .page-desc {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 4rem 0;
  }

  .series-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .series-section {
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
  }

  .series-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .series-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0;
  }

  .series-badge {
    font-size: 0.8rem;
    color: var(--color-accent);
    background-color: var(--color-border-light);
    padding: 0.2rem 0.7rem;
    border-radius: 100px;
  }

  .series-posts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .series-post {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.2s ease;
  }

  .series-post:hover {
    background-color: var(--color-border-light);
    text-decoration: none;
    color: inherit;
  }

  .series-order {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.5;
    min-width: 2rem;
    text-align: center;
  }

  .series-post-info {
    flex: 1;
  }

  .series-post-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    color: var(--color-text);
  }

  .series-post-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.3rem;
    line-height: 1.5;
  }

  .series-post time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .series-section {
      padding: 1.5rem;
    }
    .series-post {
      padding: 0.8rem;
    }
  }
</style>
