---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
  <div class="container">
    <nav class="nav">
      <a href="/Peter-blog/" class="logo">{SITE_TITLE}</a>
      <div class="nav-links">
        <a href="/Peter-blog/">首页</a>
        <a href="/Peter-blog/tags">标签</a>
        <a href="/Peter-blog/series">专题</a>
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.3s ease;
    backdrop-filter: blur(8px);
    background-color: rgba(var(--color-bg), 0.9);
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .logo:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .nav-links a {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 1.2rem;
    }
    .nav-links a {
      font-size: 0.9rem;
    }
    .logo {
      font-size: 1.2rem;
    }
  }
</style>
