<button class="theme-toggle" id="theme-toggle" aria-label="切换主题">
  <svg class="icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="5"/>
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
  </svg>
  <svg class="icon-sepia" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
  </svg>
  <svg class="icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const themes = ['light', 'sepia', 'dark'];

  function getNextTheme(current: string) {
    const idx = themes.indexOf(current);
    return themes[(idx + 1) % themes.length];
  }

  function updateIcon(theme: string) {
    if (!toggle) return;
    toggle.querySelectorAll('svg').forEach(svg => {
      (svg as HTMLElement).style.display = 'none';
    });
    const active = toggle.querySelector(`.icon-${theme}`) as HTMLElement;
    if (active) active.style.display = 'block';
  }

  const current = document.documentElement.getAttribute('data-theme') || 'light';
  updateIcon(current);

  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    const next = getNextTheme(current);
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateIcon(next);
  });
</script>

<style>
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
  }

  .theme-toggle svg {
    display: none;
  }
</style>
